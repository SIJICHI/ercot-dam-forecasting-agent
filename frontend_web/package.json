{
  "name": "frontend_web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "CI=true vite",
    "build": "cross-env NODE_ENV=production vite build",
    "lint": "npm run prettier && eslint .",
    "lint:fix": "npm run prettier:fix && eslint . --fix",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prettier": "prettier --check --config .prettierrc.json ./src ./e2e",
    "prettier:fix": "prettier --write --config .prettierrc.json ./src ./e2e",
    "test:e2e": "npx playwright test",
    "i18n:extract": "i18next-cli extract  --config ./src/lib/i18n/i18next.config.ts && npm run lint:fix"
  },
